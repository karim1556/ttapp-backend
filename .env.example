DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"
JWT_SECRET="your_long_random_secret_key"
JWT_EXPIRES_IN="7d"
# Firebase HTTP v1 credentials (recommended)
# Option A: set FCM_SERVICE_ACCOUNT_JSON as a single-line JSON string.
# Option B: set these three values directly.
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""
FCM_SERVICE_ACCOUNT_JSON=""
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000,http://localhost:8080"
RATE_LIMIT_MAX=1200
